# Option A (recommended on Dokploy): separate fields — passwords with @ ! work as-is
DB_HOST=your-dokploy-postgres-internal-hostname
DB_PORT=5432
DB_USER=dbuser
DB_PASSWORD=your-password
DB_NAME=stewarddb
DB_SSLMODE=disable

# Option B: single URL (password must be URL-encoded: @ -> %40, ! -> %21)
# DATABASE_URL=postgresql://dbuser:ENCODED_PASSWORD@HOST:5432/stewarddb?sslmode=disable

# Optional AI
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
AI_PROVIDER_ORDER=groq,gemini
AI_MAX_PROMPT_CHARS=3500
AI_MIN_REQUEST_INTERVAL_MS=4500

# Optional email / SMS
RESEND_API_KEY=
EMAIL_FROM=Steward <noreply@example.com>
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
