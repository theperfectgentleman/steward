# Required
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/stewarddb?sslmode=disable

# Optional AI
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
AI_PROVIDER_ORDER=groq,gemini
AI_MAX_PROMPT_CHARS=3500
AI_MIN_REQUEST_INTERVAL_MS=4500

# Optional email / SMS
RESEND_API_KEY=
EMAIL_FROM=Steward <noreply@example.com>
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Optional one-time seed (set to 1 only when you intentionally want seed data)
# SEED_RESET=0
