generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  SYSTEM_ADMIN
  CHURCH_EXECUTIVE
  COMMITTEE_PARTICIPANT
}

enum CommitteeTitle {
  CHAIR
  SECRETARY
  MEMBER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETE
}

enum AssignmentSource {
  PRESBYTERY
  COMMITTEE_REFERRAL
}

enum AssignmentStatus {
  DRAFT
  ASSIGNED
  ACCEPTED
  IN_PROGRESS
  IN_REVIEW
  RETURNED
  CHAIR_APPROVED
  CLOSED
  CANCELLED
}

enum AssignmentPriority {
  LOW
  NORMAL
  HIGH
}

enum EntityType {
  ASSIGNMENT
  PROJECT
  TASK
}

enum AttendanceStatus {
  PRESENT
  EXCUSED
  ABSENT
  UNMARKED
}

enum RsvpStatus {
  GOING
  DECLINED
  PENDING
}

enum DeliverableKind {
  NOTE
  LINK
}

enum DocumentSource {
  UPLOAD
  CREATED
}

enum LibraryDocumentTag {
  REPORT
  MINUTES
  POLICY
  BRIEF
  FORM
  OTHER
}

enum FeedbackType {
  ISSUE
  SUGGESTION
}

enum FeedbackStatus {
  PENDING
  REVIEWED
  DISMISSED
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
}

enum OtpChannel {
  EMAIL
  SMS
}

enum OtpPurpose {
  INVITE
  LOGIN_RESET
}

model User {
  id               String     @id @default(cuid())
  name             String
  email            String     @unique
  phone            String?
  passwordHash     String?
  status           UserStatus @default(PENDING)
  emailVerifiedAt  DateTime?
  phoneVerifiedAt  DateTime?
  role             UserRole   @default(COMMITTEE_PARTICIPANT)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  committeeMemberships CommitteeMember[]
  presbyteryMembership PresbyteryMember?
  assignedTasks        Task[]              @relation("AssignedTasks")
  createdTasks         Task[]              @relation("CreatedTasks")
  createdProjects      Project[]           @relation("CreatedProjects")
  createdAssignments   Assignment[]        @relation("CreatedAssignments")
  rsvps                EventRsvp[]
  attendances          Attendance[]
  createdMeetings      Meeting[]
  feedback             CommitteeFeedback[]
  eventDeliverables    EventDeliverable[]
  comments             Comment[]
  documents            Document[]
  libraryDocuments     LibraryDocument[]
  activityLogs         ActivityLog[]
  invitesCreated       Invite[]            @relation("InvitesCreated")
  invitesReceived      Invite[]            @relation("InvitesReceived")
  otpChallenges        OtpChallenge[]
}

model PresbyteryGroup {
  id        String             @id @default(cuid())
  name      String             @default("Presbytery")
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  members   PresbyteryMember[]
}

model PresbyteryMember {
  id        String          @id @default(cuid())
  userId    String          @unique
  groupId   String
  isHead    Boolean         @default(false)
  createdAt DateTime        @default(now())

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  group PresbyteryGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model Committee {
  id                 String   @id @default(cuid())
  charterLetter      String   @unique
  name               String
  description        String?
  budget             Float?
  reportingFrequency String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  members            CommitteeMember[]
  invites            Invite[]
  tasks              Task[]
  projects           Project[]
  events             Event[]
  meetings           Meeting[]
  timelines          TimelineGoal[]
  feedback           CommitteeFeedback[]
  targetAssignments  Assignment[]        @relation("TargetAssignments")
  sourceAssignments  Assignment[]        @relation("SourceAssignments")
  libraryDocuments   LibraryDocument[]
}

model CommitteeMember {
  id          String         @id @default(cuid())
  userId      String
  committeeId String
  title       CommitteeTitle @default(MEMBER)

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  committee Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)

  @@unique([userId, committeeId])
}

model Invite {
  id          String         @id @default(cuid())
  token       String         @unique
  userId      String
  committeeId String
  title       CommitteeTitle @default(MEMBER)
  createdById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime       @default(now())

  user      User      @relation("InvitesReceived", fields: [userId], references: [id], onDelete: Cascade)
  committee Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  createdBy User      @relation("InvitesCreated", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([userId, committeeId])
  @@index([expiresAt])
}

model OtpChallenge {
  id          String     @id @default(cuid())
  userId      String
  channel     OtpChannel
  destination String
  codeHash    String
  purpose     OtpPurpose
  expiresAt   DateTime
  consumedAt  DateTime?
  attempts    Int        @default(0)
  createdAt   DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, createdAt])
}

model Project {
  id           String        @id @default(cuid())
  title        String
  description  String?
  status       ProjectStatus @default(ACTIVE)
  committeeId  String
  assignmentId String?       @unique
  createdById  String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  committee  Committee   @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  assignment Assignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  createdBy  User        @relation("CreatedProjects", fields: [createdById], references: [id])
  tasks      Task[]
}

model Assignment {
  id                  String             @id @default(cuid())
  title               String
  description         String?
  source              AssignmentSource
  status              AssignmentStatus   @default(DRAFT)
  priority            AssignmentPriority @default(NORMAL)
  createdById         String
  targetCommitteeId   String
  sourceCommitteeId   String?
  parentAssignmentId  String?
  rootTaskId          String?            @unique
  dueDate             DateTime?
  returnComment       String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  createdBy        User       @relation("CreatedAssignments", fields: [createdById], references: [id])
  targetCommittee  Committee  @relation("TargetAssignments", fields: [targetCommitteeId], references: [id], onDelete: Cascade)
  sourceCommittee  Committee? @relation("SourceAssignments", fields: [sourceCommitteeId], references: [id], onDelete: SetNull)
  parentAssignment Assignment?  @relation("ReferralChain", fields: [parentAssignmentId], references: [id], onDelete: SetNull)
  childAssignments Assignment[] @relation("ReferralChain")
  rootTask         Task?        @relation("AssignmentRootTask", fields: [rootTaskId], references: [id], onDelete: SetNull)
  project          Project?

  @@index([targetCommitteeId, status])
  @@index([createdById, status])
  @@index([status, dueDate])
}

model Task {
  id           String     @id @default(cuid())
  title        String
  description  String?
  status       TaskStatus @default(TODO)
  dueDate      DateTime?
  committeeId  String
  projectId    String?
  eventId      String?
  parentId     String?
  assignedToId String?
  createdById  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  committee        Committee   @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  project          Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  event            Event?      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  parent           Task?       @relation("TaskSubtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks         Task[]      @relation("TaskSubtasks")
  assignedTo       User?       @relation("AssignedTasks", fields: [assignedToId], references: [id])
  createdBy        User?       @relation("CreatedTasks", fields: [createdById], references: [id])
  assignmentAsRoot Assignment? @relation("AssignmentRootTask")

  @@index([eventId])
  @@index([parentId])
  @@index([projectId])
  @@index([committeeId, assignedToId, status])
}

model Comment {
  id         String     @id @default(cuid())
  body       String
  authorId   String
  entityType EntityType
  entityId   String
  createdAt  DateTime   @default(now())

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId, createdAt])
}

model Document {
  id           String     @id @default(cuid())
  fileName     String
  storageKey   String
  mimeType     String
  entityType   EntityType
  entityId     String
  uploadedById String
  createdAt    DateTime   @default(now())

  uploadedBy User @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
}

model LibraryDocument {
  id           String             @id @default(cuid())
  title        String
  tag          LibraryDocumentTag @default(OTHER)
  source       DocumentSource     @default(CREATED)
  body         String?
  fileName     String?
  fileUrl      String?
  mimeType     String?
  committeeId  String?
  uploadedById String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  committee  Committee? @relation(fields: [committeeId], references: [id], onDelete: SetNull)
  uploadedBy User       @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([committeeId, tag, createdAt])
  @@index([tag, createdAt])
}

model ActivityLog {
  id         String     @id @default(cuid())
  entityType EntityType
  entityId   String
  action     String
  actorId    String
  metadata   Json?
  createdAt  DateTime   @default(now())

  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId, createdAt])
  @@index([actorId, createdAt])
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  committeeId String
  createdAt   DateTime  @default(now())

  committee    Committee          @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  rsvps        EventRsvp[]
  tasks        Task[]
  deliverables EventDeliverable[]
}

model EventDeliverable {
  id          String          @id @default(cuid())
  eventId     String
  title       String
  kind        DeliverableKind
  content     String
  createdById String
  createdAt   DateTime        @default(now())

  event     Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdBy User  @relation(fields: [createdById], references: [id])

  @@index([eventId])
}

model EventRsvp {
  id      String     @id @default(cuid())
  eventId String
  userId  String
  status  RsvpStatus @default(PENDING)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model Meeting {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
  committeeId String
  createdById String
  approved    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  committee   Committee     @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  createdBy   User          @relation(fields: [createdById], references: [id])
  minutes     MinutePoint[]
  attendances Attendance[]
}

model MinutePoint {
  id        String @id @default(cuid())
  content   String
  order     Int
  meetingId String

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model Attendance {
  id        String           @id @default(cuid())
  meetingId String
  userId    String
  status    AttendanceStatus @default(UNMARKED)

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
}

model TimelineGoal {
  id          String   @id @default(cuid())
  title       String
  startDate   DateTime
  endDate     DateTime
  progress    Int      @default(0)
  committeeId String

  committee Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)
}

model CommitteeFeedback {
  id          String         @id @default(cuid())
  userId      String
  committeeId String
  type        FeedbackType
  message     String
  status      FeedbackStatus @default(PENDING)
  createdAt   DateTime       @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  committee Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)

  @@index([userId, committeeId, createdAt])
  @@index([committeeId, status, createdAt])
}

model AppSettings {
  id                      String   @id @default("default")
  committeeBudgetsEnabled Boolean  @default(false)
  updatedAt               DateTime @updatedAt
}
